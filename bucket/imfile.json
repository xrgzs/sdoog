{
    "version": "2.0.1",
    "description": "Smooth,high-speed,powerful,and convenient download tool.",
    "homepage": "https://imfile.io/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v2.0.1/imFile-Setup-2.0.1.exe#/dl.7z",
            "hash": "sha512:0180d43f47e1a9cb69d3f72007a224a2109d5fd70994c4fa10bac1d32766e03b44a10a4c992459d847f02fc1e223150c2cc6c1ae1186cdd7aec1d8f6b743f7bd",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        }
    },
    "shortcuts": [
        [
            "imFile.exe",
            "imFile"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$*\" -Force -Recurse",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\imFile\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\imFile\""
    ],
    "checkver": {
        "github": "https://github.com/imfile-io/imfile-desktop"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v$version/imFile-Setup-$version.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512:\\s+$base64"
                }
            }
        }
    }
}
